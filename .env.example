# Model provider: "claude" or "openai"
MODEL_PROVIDER=openai

# Anthropic (used when MODEL_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI-compatible (used when MODEL_PROVIDER=openai)
# Groq: OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.3-70b-versatile
# xAI:  OPENAI_BASE_URL=https://api.x.ai/v1, OPENAI_MODEL=grok-beta
# OpenAI: leave OPENAI_BASE_URL empty, OPENAI_MODEL defaults to gpt-4o
OPENAI_API_KEY=your-openai-or-groq-api-key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=dbagent

# Email — get free test credentials at https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user
SMTP_PASS=your-ethereal-pass
EMAIL_FROM=agent@yourdomain.com
